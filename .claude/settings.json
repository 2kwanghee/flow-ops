{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}",
    "GEMINI_API_KEY": "${GEMINI_API_KEY}",
    "LINEAR_API_KEY": "${LINEAR_API_KEY}",
    "LINEAR_TEAM_ID": "${LINEAR_TEAM_ID}"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(python -m pytest*)",
      "Bash(python -m pytest *)",
      "Bash(cd backend && python -m pytest*)",
      "Bash(cd backend && alembic *)",
      "Bash(cd backend && ruff *)",
      "Bash(cd frontend && pnpm *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git checkout -b *)",
      "Bash(git branch*)",
      "Bash(git push -u origin ralph/*)",
      "Bash(git push origin ralph/*)",
      "Bash(gh pr *)",
      "Bash(gh auth *)",
      "Bash(docker ps*)",
      "Bash(docker compose up -d db*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker compose down*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/ralph-stop-hook.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-session.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "source \"$CLAUDE_PROJECT_DIR/scripts/pipeline_config.sh\" 2>/dev/null && is_enabled FLOWOPS_TODO_REMINDER 2>/dev/null && echo '[TODO] 작업 시작 전 TODO.md를 확인/생성하세요. 새 작업이면 기존 TODO.md를 초기화 후 새로 작성하세요.' >&2 || true"
          }
        ]
      }
    ]
  }
}
