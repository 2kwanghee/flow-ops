# ============================================================
# Flow-Ops 환경 설정
# 사용법: 이 파일을 .env로 복사한 뒤 값을 설정하세요.
#   cp .env.example .env
# ============================================================

# ── API 키 ──
LINEAR_API_KEY=
LINEAR_TEAM_ID=
OPENAI_API_KEY=
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# 자동화 모듈 ON/OFF 설정
# 각 모듈을 개별적으로 활성화/비활성화할 수 있습니다.
# 값: true (활성) | false (비활성)
# 기본값: 모두 true
# ============================================================

# 세션 종료 시 자동 커밋 (commit-session.sh)
FLOWOPS_AUTO_COMMIT=true

# Ralph 자율 루프 Stop Hook (ralph-stop-hook.sh)
FLOWOPS_RALPH_STOP_HOOK=true

# Linear 요구사항 감지 (linear_watcher.py)
FLOWOPS_LINEAR_WATCHER=true

# Linear 결과 보고 (linear_reporter.py)
FLOWOPS_LINEAR_REPORT=true

# Linear Confirm 자동 머지 (linear_confirmer.py)
FLOWOPS_LINEAR_CONFIRM=true

# PR 자동 생성 (auto_pr_creator.py)
FLOWOPS_AUTO_PR=true

# PR 자동 머지 (auto_pr_creator.py --auto-merge)
FLOWOPS_AUTO_MERGE=true

# ChatGPT 코드 리뷰 (gpt_pr_review.py)
FLOWOPS_GPT_REVIEW=true

# Telegram 알림 (telegram_notify.py)
FLOWOPS_TELEGRAM=true

# TODO.md 리마인더 (UserPromptSubmit hook)
FLOWOPS_TODO_REMINDER=true
